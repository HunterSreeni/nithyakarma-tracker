# Copy this file to keystore.properties (gitignored) and fill in real values to
# sign release builds. Generate the upload keystore first:
#
#   keytool -genkey -v -keystore nithyakarma-upload.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 -alias upload
#
# Keep the .jks file and these passwords safe and OUT of git. If you enrol in
# Play App Signing (recommended), this is only your *upload* key - losing it is
# recoverable via Google; losing an unmanaged app-signing key is not.
storeFile=nithyakarma-upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
